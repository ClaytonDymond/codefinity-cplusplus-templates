#include <iostream>

template <typename t>
void swap(t &a, t &b) {
    t temp = a;  // Store a in temp
    a = b;        // Assign b to a
    b = temp;    // Assign temp (original a) to b
}

int main()
{
    char digit = '3';
    char letter = 'a';
    swap<char>(digit, letter);
    std::cout << "Digit: " << digit << " Letter: " << letter << std::endl;
}